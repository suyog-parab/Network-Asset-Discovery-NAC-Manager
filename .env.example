# ================================================================
# NAC Manager — Environment Configuration Template
# Copy this file to .env and fill in all values.
# NEVER commit .env to version control.
# ================================================================

# ----------------------------------------------------------------
# PostgreSQL
# ----------------------------------------------------------------
DB_USER=nacuser
DB_PASS=CHANGE_ME_strong_password_here
DB_NAME=nacdb

# Port to expose PostgreSQL on the host (optional, 0 to disable)
DB_PORT_EXPOSE=5432

# Full connection URL used by the API server inside Docker
# (automatically constructed from above — only override if external DB)
# DATABASE_URL=postgresql://nacuser:CHANGE_ME@postgres:5432/nacdb

# ----------------------------------------------------------------
# Session Security
# ----------------------------------------------------------------
# Generate with: openssl rand -hex 64
SESSION_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64

# ----------------------------------------------------------------
# FreeRADIUS
# ----------------------------------------------------------------
# Shared secret between FreeRADIUS and all NAS clients (switches)
# Must match the secret in your switch dot1x/MAB configuration
RADIUS_SECRET=CHANGE_ME_radius_shared_secret

# Internal test secret used only for the health check radtest probe
RADIUS_TEST_SECRET=CHANGE_ME_internal_health_test_secret

# ----------------------------------------------------------------
# HTTP/HTTPS Ports
# ----------------------------------------------------------------
HTTP_PORT=80
HTTPS_PORT=443

# ----------------------------------------------------------------
# Logging
# ----------------------------------------------------------------
# Options: trace | debug | info | warn | error
LOG_LEVEL=info

# ----------------------------------------------------------------
# Encryption Key for stored credentials
# ----------------------------------------------------------------
# Used to encrypt SNMP passwords, LDAP bind passwords, RADIUS secrets at rest
# Generate with: openssl rand -hex 32
CREDENTIAL_ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
